# AERITH environment reference.
# Copy this file to `.env` next to docker-compose.yml.
# Naming convention: SECTION__KEY (double underscore), matching src/aerith/config.py.

# =====================================================================
# REQUIRED — the app will not run properly without these
# =====================================================================

# Postgres: application database (docker compose creates it from these values)
DB__NAME=aerith
DB__USER=aerith
DB__PASSWORD=change-me-app

# Postgres: user datasets database
DATASETS__DB__NAME=aerith_datasets
DATASETS__DB__USER=aerith_datasets
DATASETS__DB__PASSWORD=change-me-datasets

# JWT signing secret. Generate with: openssl rand -hex 32
AUTH__JWT_SECRET=change-me-in-production

# =====================================================================
# OPTIONAL — sensible defaults; uncomment only what you need
# =====================================================================

# ---- Server-wide fallback LLM provider (any OpenAI-compatible API) ----
# Users can also register their own providers in Settings -> AI Providers,
# so these are optional. When set, they act as the default for everyone.
# LLM__API_KEY=
# LLM__BASE_URL=https://api.openai.com/v1
# LLM__DEFAULT_MODEL=gpt-4o-mini

# ---- Docker compose ----
# WEB_PORT=8888                      # host port for the web UI (full stack)
# API_PORT=8000                      # host port for API (local frontend dev)
# VITE_API_BASE=/api                 # frontend build-time API prefix

# ---- Database URLs (only when running the API outside docker compose) ----
# DB__URL=postgresql+psycopg://aerith:change-me-app@localhost:5432/aerith
# DATASETS__DB__URL=postgresql+psycopg://aerith_datasets:change-me-datasets@localhost:5433/aerith_datasets

# ---- Dataset limits ----
# DATASETS__MAX_PER_USER=10
# DATASETS__MAX_PER_CHAT=10
# DATASETS__MAX_UPLOAD_MB=512
# DATASETS__UPLOAD_TMP_DIR=/tmp/aerith-uploads

# ---- Authentication ----
# AUTH__ACCESS_TTL_MINUTES=60
# AUTH__REFRESH_TTL_DAYS=14
# AUTH__COOKIE_SECURE=false          # set true behind HTTPS
# AUTH__COOKIE_SAMESITE=lax
# AUTH__INVITE_TTL_HOURS=72
# AUTH__SEED_ADMIN_LOGIN=admin       # bootstrap admin (change the password!)
# AUTH__SEED_ADMIN_PASSWORD=admin
# AUTH__SEED_ADMIN_DISPLAY_NAME=Administrator
# AUTH__DATA_KEY=                    # Fernet key for stored secrets; empty = derived from AUTH__JWT_SECRET

# ---- Chat ----
# CHAT__DEFAULT_SYSTEM_PROMPT=
# CHAT__DEFAULT_TEMPERATURE=0.5
# CHAT__WEB_SEARCH_CONTEXT_SIZE=high # low | medium | high
# CHAT__WEB_SEARCH_DEEP_READ=true    # fetch article HTML for cited links
# CHAT__AUTO_TITLE_ENABLED=true      # LLM-generated chat titles
# CHAT__TITLE_MODEL=                 # empty = default model

# ---- Analytics swarm ----
# ANALYTICS__SUBAGENT_MAX_STEPS=8
# ANALYTICS__SUBAGENT_TIMEOUT_SEC=120
# ANALYTICS__PLANNER_MODEL=          # empty = default model
# ANALYTICS__LEAD_MODEL=             # empty = default model

# ---- CORS / server ----
# CORS__ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:8888"]'
# SERVER__HOST=0.0.0.0
# SERVER__PORT=8000
# SERVER__PUBLIC_URL=http://localhost:8888   # used to build invite links
